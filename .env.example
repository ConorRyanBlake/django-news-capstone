# Django
SECRET_KEY=replace-me-with-a-secret-generated-via-django-utils
DEBUG=True

# MariaDB connection
DB_NAME=news_platform_db
DB_USER=news_user
DB_PASSWORD=replace-me
DB_HOST=localhost
DB_PORT=3306

# Email (optional in development; console backend by default)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# X / Twitter API credentials
# Required only if you want approval to actually post tweets.
# Without these, the post_to_x() service skips quietly with a log line.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Base URL used in tweet text and email links
SITE_BASE_URL=http://127.0.0.1:8000